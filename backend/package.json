{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run postbuild",
    "postbuild": "cp -r src/db/migrations dist/db/migrations && cp -r src/db/setupDatabase.ts dist/db/",
    "start": "node -r module-alias/register dist/index.js",
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "test": "jest",
    "lint": "eslint .",
    "migrate": "ts-node src/db/migrate.ts",
    "migrate:dev": "NODE_ENV=development ts-node src/db/migrate.ts",
    "migrate:prod": "NODE_ENV=production ts-node src/db/migrate.ts",
    "migrate:create": "cp src/db/migrations/template.sql src/db/migrations/$(date +%s)_new_migration.sql"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/axios": "^0.9.36",
    "@types/bull": "^3.15.9",
    "@types/express": "^5.0.1",
    "@types/form-data": "^2.2.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^10.0.0",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.5",
    "bullmq": "^5.47.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^5.1.0",
    "form-data": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "uuid": "^11.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.0",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.1.1",
    "tsconfig-paths": "^4.2.0"
  }
}
